MANTLE_RPC_MAINNET=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000

# ── Agent Wallet ──────────────────────────────────────────────────────────────
AGENT_PRIVATE_KEY=0x...
AGENT_EOA=0x...

# ── Deploy Wallet ─────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...

# ── V2 Contract Addresses ────────────────────────────────────────────────────
