# ─────────────────────────────────────────────────────────────────────────────
# Mosaic — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mantle Network ────────────────────────────────────────────────────────────
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_RPC_TESTNET=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5000

# ── Agent Wallet ──────────────────────────────────────────────────────────────
# The authorizedAgent EOA — must match the address passed to VaultFactory.
# Used by all five skill scripts to sign on-chain transactions.
AGENT_PRIVATE_KEY=0x...
AGENT_EOA=0x...

# ── Deployed Contract Addresses (filled in after Deploy.s.sol) ───────────────
DECISION_LOG_ADDRESS=0x...
VAULT_FACTORY_ADDRESS=0x...

# ── Bybit API (for BTC funding rate + market data fallback) ──────────────────
BYBIT_API_KEY=...
BYBIT_SECRET=...
BYBIT_PASSPHRASE=...

# ── Pyth Network ──────────────────────────────────────────────────────────────
PYTH_ENDPOINT=https://hermes.pyth.network/v2/updates/price/latest
# No API key required for Pyth Hermes public endpoint

# ── Pinata (IPFS storage for DecisionRecord JSON) ─────────────────────────────
PINATA_JWT=...
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Anthropic API (for Allocator LLM reasoning) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Fluxion API (fill in once Fluxion provides dev keys) ────────────
FLUXION_API_KEY=...
FLUXION_API_URL=https://api.fluxion.io/v1

# ── Optional: Explorer API key (for contract verification) ────────────────────
MANTLE_EXPLORER_KEY=...

# ── Optional: Deploy wallet (different from agent wallet) ────────────────────
PRIVATE_KEY=0x...

# ── Pipeline config overrides ─────────────────────────────────────────────────
CYCLE_INTERVAL_SECONDS=900
SIGNAL_SHIFT_THRESHOLD=10
DRY_RUN=false
LOG_LEVEL=INFO
